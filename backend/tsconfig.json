{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2021",

    "outDir": "./dist",
    "rootDir": "./src",

    "strict": false,

    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "skipLibCheck": true
  },

  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}